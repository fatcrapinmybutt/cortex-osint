      "GPS_Coordinate"
    ],
    "identity": [
      "SSN",
      "Passport",
      "Person_Name",
      "Email",
      "Phone"
    ],
    "all": []
  },
  "scoring": {
    "entity_match": 4,
    "authority_match": 2,
    "category_match": 2,
    "quote_match": 1,
    "focus_boost": 3,
    "high_threshold": 14,
    "medium_threshold": 6
  },
